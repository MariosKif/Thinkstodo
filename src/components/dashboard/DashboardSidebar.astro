---
import { getMyProfile } from '../../lib/supabase/profiles';

interface Props {
  current: 'user' | 'my-profile' | 'my-bookings' | 'my-listings' | 'bookmarks' | 'messages' | 'reviews' | 'wallet' | 'add-listing';
}
const { current } = Astro.props;

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;
let fullName = 'Welcome';
let avatarUrl = '/assets/img/team-2.jpg';
if (user && supabase) {
  const profile = await getMyProfile(supabase, user.id);
  fullName = profile?.full_name || user.email?.split('@')[0] || 'Account';
  avatarUrl = profile?.avatar_url || avatarUrl;
}
---
<div class="user-dashboard-inner h-100 border-end border-2 py-4 p-3">
	<div class="dashboard_users mb-4">
		<div class="square--80 circle mx-auto mb-1" style="overflow:hidden;"><img src={avatarUrl} class="img-fluid circle" style="width:80px;height:80px;object-fit:cover;" alt={fullName}></div>
		<div class="user-nameTitle text-center">
			<h4 class="lh-base fw-semibold text-light mb-0">Welcome Back</h4>
			<h6 class="text-light fw-medium opacity-75 mb-0">{fullName}</h6>
		</div>
	</div>
	<div class="dashboard_Menu">
		<ul>
			<li><a href="/dashboard-user/" class={current === 'user' ? 'active' : ''}><i class="bi bi-speedometer me-2"></i>Dashboard Area</a></li>
			<li><a href="/dashboard-my-profile/" class={current === 'my-profile' ? 'active' : ''}><i class="bi bi-person-lines-fill me-2"></i>My Profile</a></li>
			<li><a href="/dashboard-my-bookings/" class={current === 'my-bookings' ? 'active' : ''}><i class="bi bi-journal-check me-2"></i>My Bookings</a></li>
			<li><a href="/dashboard-my-listings/" class={current === 'my-listings' ? 'active' : ''}><i class="bi bi-ui-radios-grid me-2"></i>My Listings</a></li>
			<li><a href="/dashboard-bookmarks/" class={current === 'bookmarks' ? 'active' : ''}><i class="bi bi-bookmark-star me-2"></i>Bookmarks</a></li>
			{/* Messages + Wallet are hidden in MVP (not yet wired to real data). Toggle back on once those features ship. */}
			<li><a href="/dashboard-reviews/" class={current === 'reviews' ? 'active' : ''}><i class="bi bi-yelp me-2"></i>Reviews</a></li>
			<li><a href="/dashboard-add-listing/" class={current === 'add-listing' ? 'active' : ''}><i class="bi bi-patch-plus me-2"></i>Add Listing</a></li>
		</ul>
	</div>
</div>
