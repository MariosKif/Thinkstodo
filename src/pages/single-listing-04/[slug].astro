import Preloader from '../../components/shared/Preloader.astro';
import { features, gallerys3, authors, listings2 } from '../../lib/data/context';

function slugify(s: string): string {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

export async function getStaticPaths() {
  const { events } = await import('../../lib/data/context');
  const slugifyFn = (s: string) =>
    s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  return events.map((event) => ({
    params: { slug: (event as any).slug || slugifyFn((event as any).title) },
    props: { event },
  }));
}

const { event } = Astro.props as { event: any };
const heroImg = event.img || '/assets/img/single-4.jpg';
