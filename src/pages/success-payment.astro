---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
---
<Base title="Payment Successful - ThinksToDo">
  <Navbar headerClass="header header-light head-shadow" />

<Preloader />

<div class="clearfix"></div>

<!-- Payment Info Start -->
<section class="bg-cover" style="background: #ffe8ee url(/assets/img/auth-bg.png) no-repeat;">
	<div class="container">
		<div class="row align-items-center justify-content-center pt-lg-0 pt-5">
			<div class="col-xl-5 col-lg-7 col-md-9">
				<div class="confirmsWrap">

					<div class="confirmsbody d-black mb-4">
						<div class="card rounded-4 p-sm-5 p-4">
							<div class="card-body p-0">


								<!-- Title -->
								<div class="checkBox">
									<span class="check"><i class="bi bi-patch-check-fill"></i></span>
								</div>

								<div class="confirmsHeads">
									<h3 class="successTitle">Congratulations!</h3>
									<p class="successSubtitle">Your order has been received successfully. </p>
								</div>

								<!-- OrderInfo Start -->
								<div class="confirmsInfo">
									<ul>
										<li>
											<span class="headTitle">Order ID</span>
											<span class="headCaps">54231</span>
										</li>
										<li>
											<span class="headTitle">Payment Status</span>
											<span class="headCaps"><i class="bi bi-check-circle-fill text-success me-1"></i>Compeleted</span>
										</li>
										<li>
											<span class="headTitle">Payment Date</span>
											<span class="headCaps">Jul 17 2025, 10:40:25</span>
										</li>
										<li>
											<span class="headTitle">Total Amount</span>
											<span class="headCaps">$276.85</span>
										</li>
									</ul>
								</div>
								<!-- OrderInfo END -->

							</div>

						</div>
					</div>

				</div>

			</div>
		</div>
	</div>
</section>
<!-- Payment Info End -->


<!-- Call To Action Start -->
<section class="bg-cover bg-primary-2 position-relative py-5" style="background:url(/assets/img/brand-section.png)no-repeat;">
	<div class="container">

		<!-- Components/Home/index/subscribe.html -->
		<Subscribe />

	</div>
</section>
<!-- Call To Action Start -->


	<!-- Components/Home/index/log.html -->
	<LoginModal />


	<!-- Components/Home/index/cart.html -->
	<!-- Components/Home/index/search.html -->
	<SearchOffcanvas />


	<Footer />
</Base>
